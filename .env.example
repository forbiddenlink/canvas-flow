# CanvasFlow Environment Variables

# Database (SQLite for development, PostgreSQL for production)
DATABASE_URL="postgresql://user:password@localhost:5432/canvasflow"
# For development with SQLite:
# DATABASE_URL="file:./dev.db"

# Authentication
NEXTAUTH_SECRET="your-secret-key-here-generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# OAuth Providers (Optional - uncomment to enable)
# Google OAuth
# GOOGLE_CLIENT_ID="your-google-client-id"
# GOOGLE_CLIENT_SECRET="your-google-client-secret"

# GitHub OAuth
# GITHUB_ID="your-github-client-id"
# GITHUB_SECRET="your-github-client-secret"

# AI API Keys (required for generation features)
# Get from /tmp/api-key for testing, or from replicate.com
REPLICATE_API_KEY="your_replicate_api_key_here"

# Optional: Additional AI Providers
FAL_AI_API_KEY="your_fal_ai_api_key_here"
STABILITY_API_KEY="your_stability_api_key_here"

# Storage (optional for development, required for production)
STORAGE_ACCESS_KEY="your_storage_access_key"
STORAGE_SECRET_KEY="your_storage_secret_key"
STORAGE_BUCKET="pixelforge-images"
STORAGE_REGION="auto"
STORAGE_ENDPOINT="https://your-account.r2.cloudflarestorage.com"

# Rate Limiting (optional for development)
UPSTASH_REDIS_URL="your_upstash_redis_url"
UPSTASH_REDIS_TOKEN="your_upstash_redis_token"

# Analytics (optional)
NEXT_PUBLIC_VERCEL_ANALYTICS_ID="your_analytics_id"
SENTRY_DSN="your_sentry_dsn"
