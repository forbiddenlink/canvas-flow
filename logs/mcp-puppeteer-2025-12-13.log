{"arguments":{"script":"\n// Simulate drawing a rectangle on the canvas\nconst canvas = document.querySelector('canvas');\nif (canvas) {\n  const rect = canvas.getBoundingClientRect();\n  \n  // Create and dispatch mousedown event\n  const mouseDown = new MouseEvent('mousedown', {\n    bubbles: true,\n    cancelable: true,\n    clientX: rect.left + 400,\n    clientY: rect.top + 300,\n    button: 0\n  });\n  canvas.dispatchEvent(mouseDown);\n  \n  // Create and dispatch mousemove event\n  const mouseMove = new MouseEvent('mousemove', {\n    bubbles: true,\n    cancelable: true,\n    clientX: rect.left + 600,\n    clientY: rect.top + 450,\n    button: 0\n  });\n  canvas.dispatchEvent(mouseMove);\n  \n  // Create and dispatch mouseup event\n  const mouseUp = new MouseEvent('mouseup', {\n    bubbles: true,\n    cancelable: true,\n    clientX: rect.left + 600,\n    clientY: rect.top + 450,\n    button: 0\n  });\n  canvas.dispatchEvent(mouseUp);\n  \n  'Rectangle drawn';\n} else {\n  'Canvas not found';\n}\n"},"level":"debug","message":"Tool call received","service":"mcp-puppeteer","timestamp":"2025-12-13 09:10:54.380","tool":"puppeteer_evaluate"}
