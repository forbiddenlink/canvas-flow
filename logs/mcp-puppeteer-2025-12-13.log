{"arguments":{"script":"\n// Try to add an image by accessing the Zustand store\n(async () => {\n  // Wait a bit for the page to fully load\n  await new Promise(resolve => setTimeout(resolve, 1000));\n  \n  // Try multiple ways to access the canvas\n  let fabricCanvas = null;\n  \n  // Try window global\n  if (window.fabricCanvas) {\n    fabricCanvas = window.fabricCanvas;\n  } else if (window.__fabricCanvas) {\n    fabricCanvas = window.__fabricCanvas;\n  } else {\n    // Try to find canvas element\n    const canvasEl = document.querySelector('canvas');\n    if (canvasEl && canvasEl.__fabric) {\n      fabricCanvas = canvasEl.__fabric;\n    }\n  }\n  \n  if (!fabricCanvas) {\n    return { success: false, message: 'Could not find Fabric canvas instance' };\n  }\n  \n  // Create a simple colored rectangle as test image\n  const dataUrl = 'data:image/png;base64,';\n  \n  return new Promise((resolve) => {\n    fabric.Image.fromURL(dataUrl, (img) => {\n      img.set({\n        left: 300,\n        top: 200,\n        scaleX: 0.5,\n        scaleY: 0.5\n      });\n      fabricCanvas.add(img);\n      fabricCanvas.setActiveObject(img);\n      fabricCanvas.renderAll();\n      resolve({ success: true, message: 'Image added to canvas' });\n    });\n  });\n})()\n"},"level":"debug","message":"Tool call received","service":"mcp-puppeteer","timestamp":"2025-12-13 09:12:38.728","tool":"puppeteer_evaluate"}
