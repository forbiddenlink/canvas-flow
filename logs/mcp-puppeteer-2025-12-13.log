{"arguments":{"script":"\n// Create and load a test image directly into fabric canvas\n(async () => {\n  // Access the canvas from the window or find it\n  const canvasEl = document.querySelector('canvas');\n  if (!canvasEl) return 'Canvas not found';\n  \n  // Create test image data URL\n  const testCanvas = document.createElement('canvas');\n  testCanvas.width = 400;\n  testCanvas.height = 300;\n  const ctx = testCanvas.getContext('2d');\n  \n  // Create colorful gradient\n  const gradient = ctx.createLinearGradient(0, 0, 400, 300);\n  gradient.addColorStop(0, '#FF6B6B');\n  gradient.addColorStop(0.5, '#4ECDC4');\n  gradient.addColorStop(1, '#45B7D1');\n  ctx.fillStyle = gradient;\n  ctx.fillRect(0, 0, 400, 300);\n  \n  // Add a yellow circle\n  ctx.fillStyle = '#FFE66D';\n  ctx.beginPath();\n  ctx.arc(200, 150, 80, 0, Math.PI * 2);\n  ctx.fill();\n  \n  const imageUrl = testCanvas.toDataURL('image/png');\n  \n  // Try to access fabric canvas through window or global scope\n  // The canvas should be accessible through the Zustand store\n  return `Image data URL created: ${imageUrl.substring(0, 50)}...`;\n})();\n"},"level":"debug","message":"Tool call received","service":"mcp-puppeteer","timestamp":"2025-12-13 03:15:12.589","tool":"puppeteer_evaluate"}
