{"arguments":{"script":"\n(async () => {\n  // Create a test image using a data URL\n  const canvas = document.createElement('canvas');\n  canvas.width = 400;\n  canvas.height = 300;\n  const ctx = canvas.getContext('2d');\n  \n  // Create a colorful gradient test image\n  const gradient = ctx.createLinearGradient(0, 0, 400, 300);\n  gradient.addColorStop(0, '#FF6B6B');\n  gradient.addColorStop(0.5, '#4ECDC4');\n  gradient.addColorStop(1, '#45B7D1');\n  ctx.fillStyle = gradient;\n  ctx.fillRect(0, 0, 400, 300);\n  \n  // Add some shapes for variety\n  ctx.fillStyle = '#FFD93D';\n  ctx.fillRect(50, 50, 100, 100);\n  \n  ctx.fillStyle = '#6BCB77';\n  ctx.beginPath();\n  ctx.arc(300, 150, 60, 0, Math.PI * 2);\n  ctx.fill();\n  \n  const dataUrl = canvas.toDataURL('image/png');\n  \n  // Access the Fabric canvas from the global store\n  const fabricCanvas = window.__fabricCanvas;\n  if (!fabricCanvas) {\n    return 'Fabric canvas not found in window';\n  }\n  \n  // Add image to Fabric canvas\n  return new Promise((resolve) => {\n    fabric.Image.fromURL(dataUrl, (img) => {\n      img.set({\n        left: 300,\n        top: 200,\n        scaleX: 1,\n        scaleY: 1\n      });\n      fabricCanvas.add(img);\n      fabricCanvas.setActiveObject(img);\n      fabricCanvas.renderAll();\n      resolve('Image added to canvas successfully');\n    });\n  });\n})()\n"},"level":"debug","message":"Tool call received","service":"mcp-puppeteer","timestamp":"2025-12-13 09:12:15.589","tool":"puppeteer_evaluate"}
