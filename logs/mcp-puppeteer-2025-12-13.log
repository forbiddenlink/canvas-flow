{"arguments":{"script":"\n// Find the container that has the Layers/History/Properties/Adjustments tabs\nconst allElements = Array.from(document.querySelectorAll('*'));\nfor (const el of allElements) {\n  const text = el.textContent;\n  if (text && text.includes('Layers') && text.includes('History') && text.includes('Properties') && text.includes('Adjustments')) {\n    // Found the tab container, now find its parent to see the full right panel\n    const parent = el.parentElement;\n    const grandparent = parent?.parentElement;\n    \n    return {\n      found: true,\n      elementTag: el.tagName,\n      parentTag: parent?.tagName,\n      grandparentTag: grandparent?.tagName,\n      parentDisplay: parent ? window.getComputedStyle(parent).display : null,\n      parentWidth: parent?.offsetWidth,\n      parentHeight: parent?.offsetHeight,\n      hasHiddenClass: parent?.className.includes('hidden'),\n      containerText: el.textContent?.substring(0, 300)\n    };\n  }\n}\nreturn { found: false };\n"},"level":"debug","message":"Tool call received","service":"mcp-puppeteer","timestamp":"2025-12-13 03:33:10.760","tool":"puppeteer_evaluate"}
