{"arguments":{"script":"\n// Check what's in the right panel area - look for the adjustments panel content\nconst adjustmentsText = document.body.innerText;\nconst hasPresetFilters = adjustmentsText.includes('Preset Filters');\nconst hasVintage = adjustmentsText.includes('Vintage');\nconst hasFilterStrength = adjustmentsText.includes('Filter Strength');\nconst hasBeforeAfter = adjustmentsText.includes('Before/After') || adjustmentsText.includes('Show Before/After');\n\nreturn {\n  hasPresetFilters,\n  hasVintage,\n  hasFilterStrength,\n  hasBeforeAfter,\n  adjustmentsTabText: adjustmentsText.includes('Adjustments'),\n};\n"},"level":"debug","message":"Tool call received","service":"mcp-puppeteer","timestamp":"2025-12-13 03:15:51.355","tool":"puppeteer_evaluate"}
