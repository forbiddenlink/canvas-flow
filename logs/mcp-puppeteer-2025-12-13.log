{"arguments":{"script":"\n// Check for any error messages or generated images\nconst modal = document.querySelector('[role=\"dialog\"]') || document.querySelector('.modal');\nconst errorMessages = Array.from(document.querySelectorAll('*')).filter(el => {\n  const text = el.textContent;\n  return text.includes('error') || text.includes('Error') || text.includes('failed') || text.includes('Failed') || text.includes('insufficient') || text.includes('402');\n});\n\nconst generatedImages = document.querySelectorAll('img[src*=\"replicate\"]');\n\nreturn {\n  hasError: errorMessages.length > 0,\n  errorText: errorMessages.map(el => el.textContent.substring(0, 200)).join(' | '),\n  hasGeneratedImage: generatedImages.length > 0,\n  imageCount: generatedImages.length\n};\n"},"level":"debug","message":"Tool call received","service":"mcp-puppeteer","timestamp":"2025-12-13 10:13:02.543","tool":"puppeteer_evaluate"}
