{"arguments":{"script":"\n// Check if the right sidebar exists and is visible\nconst rightSidebar = document.querySelector('[class*=\"right\"]');\nconst allDivs = document.querySelectorAll('div');\nlet foundAdjustments = false;\nfor (const div of allDivs) {\n  if (div.textContent?.includes('Select an image to adjust')) {\n    foundAdjustments = true;\n    return {\n      found: true,\n      visible: div.offsetParent !== null,\n      display: window.getComputedStyle(div).display,\n      width: div.offsetWidth,\n      height: div.offsetHeight\n    };\n  }\n}\nreturn { found: foundAdjustments, message: 'Adjustments panel not found in DOM' };\n"},"level":"debug","message":"Tool call received","service":"mcp-puppeteer","timestamp":"2025-12-13 03:16:01.686","tool":"puppeteer_evaluate"}
