{"arguments":{"script":"\n// Create a test image using canvas and add it to the Fabric canvas\nasync function addTestImage() {\n  // Create a small test image using canvas\n  const testCanvas = document.createElement('canvas');\n  testCanvas.width = 400;\n  testCanvas.height = 300;\n  const ctx = testCanvas.getContext('2d');\n  \n  // Draw a colorful gradient background\n  const gradient = ctx.createLinearGradient(0, 0, 400, 300);\n  gradient.addColorStop(0, '#FF6B6B');\n  gradient.addColorStop(0.5, '#4ECDC4');\n  gradient.addColorStop(1, '#45B7D1');\n  ctx.fillStyle = gradient;\n  ctx.fillRect(0, 0, 400, 300);\n  \n  // Add some shapes for visual interest\n  ctx.fillStyle = '#FFE66D';\n  ctx.beginPath();\n  ctx.arc(100, 100, 50, 0, Math.PI * 2);\n  ctx.fill();\n  \n  ctx.fillStyle = '#A8E6CF';\n  ctx.fillRect(250, 150, 100, 100);\n  \n  // Convert to data URL\n  const dataURL = testCanvas.toDataURL('image/png');\n  \n  // Try to add to Fabric canvas via Zustand store\n  // Check if addImageLayer function is available\n  if (window.useCanvasStore) {\n    const store = window.useCanvasStore.getState();\n    if (store.addImageLayer) {\n      await store.addImageLayer(dataURL);\n      return 'Test image added via addImageLayer';\n    }\n  }\n  \n  return 'Store or addImageLayer not found: ' + dataURL.substring(0, 50);\n}\n\nawait addTestImage();\n"},"level":"debug","message":"Tool call received","service":"mcp-puppeteer","timestamp":"2025-12-13 09:25:53.547","tool":"puppeteer_evaluate"}
