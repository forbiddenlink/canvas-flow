{"arguments":{"script":"\n// Access the canvas store and fabric canvas\nconst canvasStoreState = window.__CANVAS_STORE__ || {};\n\n// Create a test image programmatically\nconst img = new Image();\nimg.crossOrigin = 'anonymous';\n\n// Create a colorful test image as data URL\nconst createTestImageDataURL = () => {\n  const canvas = document.createElement('canvas');\n  canvas.width = 800;\n  canvas.height = 600;\n  const ctx = canvas.getContext('2d');\n  \n  // Create a colorful gradient background\n  const gradient = ctx.createLinearGradient(0, 0, 800, 600);\n  gradient.addColorStop(0, '#FF6B6B');\n  gradient.addColorStop(0.5, '#4ECDC4');\n  gradient.addColorStop(1, '#45B7D1');\n  ctx.fillStyle = gradient;\n  ctx.fillRect(0, 0, 800, 600);\n  \n  // Add colorful shapes\n  ctx.fillStyle = '#FFE66D';\n  ctx.fillRect(100, 100, 200, 150);\n  \n  ctx.fillStyle = '#A8E6CF';\n  ctx.beginPath();\n  ctx.arc(600, 300, 100, 0, Math.PI * 2);\n  ctx.fill();\n  \n  // Add some text\n  ctx.font = 'bold 48px Arial';\n  ctx.fillStyle = 'white';\n  ctx.strokeStyle = 'black';\n  ctx.lineWidth = 3;\n  ctx.strokeText('TEST IMAGE', 250, 350);\n  ctx.fillText('TEST IMAGE', 250, 350);\n  \n  return canvas.toDataURL('image/png');\n};\n\nimg.src = createTestImageDataURL();\n\nimg.onload = () => {\n  // Find the fabric canvas\n  const fabricCanvas = window.canvas || window.__fabricCanvas;\n  \n  if (fabricCanvas && window.fabric) {\n    // Create fabric image\n    const fabricImg = new window.fabric.Image(img, {\n      left: 100,\n      top: 100,\n      scaleX: 0.5,\n      scaleY: 0.5\n    });\n    \n    fabricCanvas.add(fabricImg);\n    fabricCanvas.setActiveObject(fabricImg);\n    fabricCanvas.renderAll();\n    \n    console.log('Test image added to canvas');\n  }\n};\n\n'Creating and adding test image to canvas...';\n"},"level":"debug","message":"Tool call received","service":"mcp-puppeteer","timestamp":"2025-12-13 07:45:26.844","tool":"puppeteer_evaluate"}
