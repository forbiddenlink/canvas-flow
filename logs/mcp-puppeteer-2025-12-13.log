{"arguments":{"script":"\n// Check if we can find a button or element that would indicate the right sidebar is collapsed\n// and try to expand it\nconst buttons = Array.from(document.querySelectorAll('button'));\n\n// Look for any chevron or expand buttons on the right side\nconst expandButtons = buttons.filter(b => {\n  const ariaLabel = b.getAttribute('aria-label');\n  const title = b.getAttribute('title');\n  return ariaLabel?.includes('Expand') || ariaLabel?.includes('Show') || \n         title?.includes('Expand') || title?.includes('Show');\n});\n\nif (expandButtons.length > 0) {\n  expandButtons[0].click();\n  return `Found and clicked expand button: ${expandButtons[0].getAttribute('aria-label') || expandButtons[0].getAttribute('title')}`;\n}\n\n// Also check if the right sidebar state is accessible\nreturn {\n  expandButtonsFound: expandButtons.length,\n  message: 'Looking for collapsed sidebar'\n};\n"},"level":"debug","message":"Tool call received","service":"mcp-puppeteer","timestamp":"2025-12-13 04:06:18.044","tool":"puppeteer_evaluate"}
