{"arguments":{"script":"\n// Look for specific error messages in the visible content\nconst allText = document.body.innerText;\nconst hasInsufficientCredit = allText.includes('insufficient credit') || allText.includes('Insufficient credit');\nconst has402Error = allText.includes('402');\nconst hasPaymentRequired = allText.includes('Payment Required');\n\n// Also check for specific error elements\nconst errorDivs = Array.from(document.querySelectorAll('div, p, span')).filter(el => {\n  const style = window.getComputedStyle(el);\n  const text = el.textContent.toLowerCase();\n  return (style.color.includes('rgb(239, 68, 68)') || style.color.includes('red')) && \n         (text.includes('error') || text.includes('failed') || text.includes('insufficient'));\n});\n\nreturn {\n  hasInsufficientCredit,\n  has402Error,\n  hasPaymentRequired,\n  errorDivsCount: errorDivs.length,\n  errorTexts: errorDivs.slice(0, 3).map(el => el.textContent.trim().substring(0, 300))\n};\n"},"level":"debug","message":"Tool call received","service":"mcp-puppeteer","timestamp":"2025-12-13 10:13:20.419","tool":"puppeteer_evaluate"}
